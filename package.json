{
  "name": "@sipheron/vdr-core",
  "version": "0.1.26",
  "description": "SipHeron VDR Official JavaScript/TypeScript SDK. Cryptographically anchor documents to Solana.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/hash/browser.d.ts",
      "require": "./dist/hash/browser.js",
      "default": "./dist/hash/browser.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "scripts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "document-verification",
    "blockchain",
    "solana",
    "sha256",
    "tamper-proof",
    "notarization",
    "vdr",
    "sipheron"
  ],
  "author": "SipHeron VDR <admin@sipheron.com>",
  "license": "Apache-2.0",
  "homepage": "https://app.sipheron.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/SipHeron-VDR/vdr-core"
  },
  "bugs": {
    "url": "https://github.com/SipHeron-VDR/vdr-core/issues",
    "email": "security@sipheron.com"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
